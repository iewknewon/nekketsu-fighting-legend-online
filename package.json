{
  "name": "nekketsu-fighting-legend-online",
  "version": "1.0.0",
  "description": "热血格斗传说浏览器联机版",
  "main": "online-server/server.js",
  "scripts": {
    "online": "node online-server/server.js",
    "online:start-local": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\start-online-local.ps1",
    "online:stop-local": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\stop-online-local.ps1",
    "online:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\smoke-online.ps1",
    "online:room-smoke": "node .\\tools\\smoke-netplay-room.js",
    "online:advanced-smoke": "node .\\tools\\smoke-netplay-advanced.js",
    "online:password-smoke": "node .\\tools\\smoke-netplay-password.js"
  },
  "keywords": [
    "nekketsu",
    "nes",
    "browser-netplay",
    "emulatorjs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@emulatorjs/core-fceumm": "^4.2.3",
    "@emulatorjs/core-nestopia": "^4.2.3",
    "@emulatorjs/emulatorjs": "^4.2.3",
    "express": "^5.2.1",
    "socket.io": "^4.8.3"
  }
}
